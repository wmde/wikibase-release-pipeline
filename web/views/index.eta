<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <title>Wikibase Suite Deploy Setup</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@picocss/pico@1.5.10/css/pico.min.css"
  />
  <script src="https://cdn.jsdelivr.net/npm/just-validate@4.3.0/dist/just-validate.production.min.js"></script>
  <style>
    :root {
      --font-size: 15px;
      --spacing: 0.9rem;
      --tab-active-bg: #ffffff;
      --shell-bg: #f5f7fb;
      --panel-bg: #ffffff;
      --panel-border: #d9e1ee;
      --panel-shadow: 0 10px 30px rgba(8, 22, 52, 0.05);
      --status-bg: #eef5ff;
      --status-border: #bcd3f5;
      --status-text: #243b67;
      --locked-bg: #f8fafc;
      --locked-border: #d5dee9;
      --muted-text: #49566e;
    }

    body {
      min-height: 100vh;
      margin: 0;
      background: radial-gradient(circle at top left, #ffffff 0%, var(--shell-bg) 55%, #edf2f8 100%);
      padding: 0.65rem 1.15rem 1.15rem;
      font-size: 15px;
    }

    main {
      max-width: 980px;
      margin: auto;
      width: 100%;
    }

    body > main {
      padding: 0 !important;
    }

    #header {
      display: flex;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 0.9rem;
      margin-bottom: 1.25rem;
      padding: 0.7rem 0.8rem;
      border: 1px solid #d8e1ee;
      border-radius: 16px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(243, 248, 255, 0.96) 100%);
      box-shadow: 0 8px 24px rgba(15, 33, 68, 0.06);
    }

    #header-brand {
      display: flex;
      gap: 0.95rem;
      align-items: center;
    }

    #header img {
      height: 56px;
      width: auto;
      flex-shrink: 0;
    }

    #header-copy {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    #header h1 {
      margin: 0;
      font-size: 1.22rem;
      letter-spacing: -0.01em;
      line-height: 1.1;
      color: #16243d;
    }

    #header-subtitle {
      margin: 0;
      color: #4f5f78;
      font-size: 0.79rem;
      line-height: 1.25;
    }

    #setup-steps {
      display: block;
      margin: 0;
      padding: 0;
      border-bottom: 1px solid var(--panel-border);
      position: relative;
      z-index: 3;
    }

    #setup-steps ol {
      display: flex;
      align-items: flex-end;
      gap: 0.35rem;
      list-style: none;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
    }

    #setup-steps ol:first-of-type,
    #setup-steps ol:last-of-type {
      margin-left: 0;
      margin-right: 0;
    }

    #setup-steps li {
      margin: 0;
      padding: 0 !important;
      list-style: none;
    }

    #setup-steps li::before {
      content: none !important;
    }

    #setup-steps li.step-item {
      flex: 0 0 auto;
    }

    #setup-steps li.log-item {
      margin-left: auto;
    }

    .step {
      appearance: none;
      width: auto;
      display: flex;
      align-items: center;
      gap: 0.48rem;
      padding: 0.46rem 0.62rem;
      min-height: 2.7rem;
      border-radius: 12px 12px 0 0;
      border: 1px solid var(--panel-border);
      border-bottom-color: var(--panel-border);
      background: #edf3fb;
      text-align: left;
      cursor: pointer;
      color: #5f6d84;
      transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
      margin: 0 0 -1px;
    }

    .step-item .step {
      min-width: 11.7rem;
    }

    .step-index {
      width: 1.18rem;
      height: 1.18rem;
      border-radius: 999px;
      border: 1px solid #b8c5dd;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.69rem;
      font-weight: 700;
      flex-shrink: 0;
      background: #fff;
    }

    .step-label {
      font-size: 0.77rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      line-height: 1.2;
    }

    .step.is-current {
      color: #5f6d84;
    }

    .step.is-current .step-index {
      border-color: #b8c5dd;
      color: inherit;
    }

    .step.is-active {
      border-color: var(--panel-border);
      border-bottom-color: var(--tab-active-bg);
      background: #fff;
      position: relative;
      z-index: 2;
      box-shadow: none;
    }

    .step[disabled] {
      cursor: default;
      opacity: 1;
    }

    .step[disabled]:not(.is-done):not(.is-current) {
      color: #9ca8b8;
      background: #f1f4f8;
      border-color: #dbe2ec;
    }

    .step[disabled]:not(.is-done):not(.is-current) .step-index {
      border-color: #ccd5e2;
      background: #f8fafc;
      color: #b2bccb;
    }

    .step[aria-selected='true'] {
      border-color: var(--panel-border);
      border-bottom-color: var(--tab-active-bg);
      box-shadow: none;
    }

    .step.is-done {
      color: #5f6d84;
      background: #edf3fb;
      border-color: var(--panel-border);
    }

    .step.is-done .step-index {
      border-color: #4f8f74;
      background: #4f8f74;
      color: #fff;
      font-size: 0.68rem;
    }

    .panel {
      background: var(--panel-bg);
      border: 1px solid var(--panel-border);
      border-top: 0;
      border-radius: 0 0 16px 16px;
      box-shadow: var(--panel-shadow);
      padding: 0.86rem 0.9rem 0.8rem;
      margin-top: 0;
    }

    #setup-layout {
      margin-top: 0;
      position: relative;
      z-index: 1;
    }

    .panel > h3 {
      margin: 0 0 0.35rem;
      font-size: 0.98rem;
      letter-spacing: 0.01em;
    }

    #config-locked-note {
      margin: 0 0 0.7rem;
      color: #3f4e66;
      font-size: 0.84rem;
      line-height: 1.35;
      font-weight: 600;
    }

    #config-section.is-locked {
      border-color: var(--panel-border);
      background: var(--panel-bg);
    }

    #config-section.is-locked input,
    #config-section.is-locked button,
    #config-section.is-locked details {
      opacity: 0.86;
    }

    #config-form button[type='submit'][disabled] {
      background: #adb8c5 !important;
      border-color: #adb8c5 !important;
      color: #f2f6fa !important;
      opacity: 1;
      filter: saturate(0.45);
      cursor: not-allowed;
    }

    #config-content {
      background-color: #111;
      color: #eee;
      font-size: 0.66rem;
      font-family: monospace;
      padding: 1em;
      border-radius: 0.5rem;
      overflow-x: auto;
      white-space: pre;
    }

    #log-content *::selection,
    #log-content::selection,
    #config-content *::selection,
    #config-content::selection {
      background-color: var(--primary);
      color: var(--primary-inverse);
    }

    #copy-config,
    #download-config {
      margin-top: 0.5rem;
      margin-right: 1rem;
    }

    label {
      font-weight: bold;
      font-size: 0.86rem;
    }

    label:has(.field-help) input {
      margin-bottom: 1rem;
    }

    label:has(.just-validate-error-label) input {
      margin-bottom: 0;
    }

    .field-help {
      font-weight: normal;
      font-size: 0.71rem;
      color: #5a667b;
    }

    .field-help .help-actions {
      float: right;
    }

    .just-validate-error-label {
      font-weight: normal;
      font-size: 0.7rem;
    }

    .just-validate-error-field {
      border: solid 3px;
      border-color: rgb(197, 47, 33);
    }

    #status-intro {
      margin: 0 0 0.75rem;
      color: var(--muted-text);
      font-size: 0.82rem;
    }

    #waiting {
      margin-top: 0.35rem;
      font-size: 0.86rem;
      color: var(--status-text);
      white-space: pre-wrap;
      background: var(--status-bg);
      border: 1px solid var(--status-border);
      border-radius: 12px;
      padding: 0.72rem 0.85rem;
    }

    .status-line {
      position: relative;
      margin: 0.2rem 0 0.2rem 0.95rem;
    }

    .status-line::before {
      content: '';
      position: absolute;
      left: -0.72rem;
      top: 0.48rem;
      width: 0.33rem;
      height: 0.33rem;
      border-radius: 999px;
      background: #4667a2;
    }

    #complete {
      margin-top: 0.55rem;
      border-top: 1px solid #e5ebf5;
      padding-top: 0.9rem;
    }

    #complete p {
      margin-bottom: 0.9rem;
    }

    #saved-config {
      margin-top: 0.9rem;
    }

    #saved-config p {
      margin-bottom: 0.45rem;
    }

    #log-section pre {
      background-color: #111;
      color: #eee;
      font-family: monospace;
      font-size: 0.74rem;
      padding: 1rem;
      border-radius: 0.5rem;
      max-height: 52vh;
      overflow: auto;
      margin: 0.4rem 0 0.8rem;
    }
    #log-section pre *::selection, #log-section pre::selection {
      background-color: var(--primary);
      color: var(--primary-inverse);
    }

    .utility-tab {
      width: auto;
      min-width: 5.3rem;
      justify-content: center;
      padding-inline: 0.72rem;
      border-color: #c4d5f1;
      background: #edf4ff;
      color: #2a4f86;
    }

    .utility-tab.is-active,
    .utility-tab[aria-selected='true'] {
      border-color: var(--panel-border);
      border-bottom-color: var(--tab-active-bg);
      background: #fff;
      color: #1f3f73;
      box-shadow: none;
    }

    .utility-tab .step-label {
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    #log-actions {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
      padding: 0.45rem 0.65rem;
      border: 1px solid #f0d8d8;
      border-radius: 10px;
      background: #fff8f8;
    }

    #shutdown-btn {
      margin: 0;
      width: auto !important;
      min-width: 9.25rem;
      display: inline-flex !important;
      flex: 0 0 auto;
      justify-content: center;
      align-self: start;
      padding: 0.42rem 0.74rem;
      font-size: 0.8rem;
      line-height: 1.2;
      border-color: #d44c47 !important;
      background: #d44c47 !important;
      color: #fff !important;
    }

    #shutdown-btn:hover,
    #shutdown-btn:focus-visible {
      border-color: #b9322d !important;
      background: #b9322d !important;
      color: #fff !important;
    }

    #shutdown-help {
      margin: 0;
      color: #6d5151;
      font-size: 0.78rem;
      line-height: 1.3;
      max-width: 46rem;
    }

    #shutdown-msg {
      margin: 0.45rem 0 0;
      color: var(--muted-text);
      font-size: 0.79rem;
      grid-column: 1 / -1;
    }

    #shutdown-msg:empty {
      display: none;
    }

    #step-log {
      margin-left: 0;
    }

    #step-log:hover,
    #step-log:focus-visible {
      border-color: #9cb7e4;
      background: #e6f0ff;
    }

    @media (max-width: 700px) {
      body {
        padding: 0.5rem 0.72rem 0.72rem;
      }

      #header {
        flex-direction: column;
        align-items: stretch;
      }

      #header-brand {
        align-items: flex-start;
      }

      #header img {
        height: 52px;
      }

      #header h1 {
        font-size: 1.26rem;
      }

      #header-subtitle {
        font-size: 0.82rem;
      }

      #setup-steps ol {
        display: grid;
        grid-template-columns: 1fr;
      }

      #setup-steps li.step-item {
        flex: 1 1 100%;
      }

      #setup-steps li.log-item {
        margin-left: 0;
        justify-self: stretch;
        width: 100%;
      }

      #step-log {
        width: 100%;
        border-radius: 10px;
        margin-bottom: 0;
        margin-left: 0;
      }

      #log-actions {
        grid-template-columns: 1fr;
      }

      #shutdown-btn {
        align-self: start;
      }

      .panel {
        padding: 0.85rem 0.75rem;
      }
    }
  </style>
</head>
<body>
  <main>
    <div id="header">
      <div id="header-brand">
        <img src="/Wikibase_Suite_(RGB).png" alt="Wikibase Logo" />
        <div id="header-copy">
          <h1>Deploy Setup</h1>
          <p id="header-subtitle">Configure your instance, then watch services start in real time.</p>
        </div>
      </div>
    </div>

    <nav id="setup-steps" aria-label="Setup steps">
      <ol role="tablist" aria-label="Setup stages">
        <li class="step-item">
          <button id="step-config" type="button" class="step is-active is-current" aria-selected="true" aria-controls="config-section" role="tab">
            <span class="step-index">1</span>
            <span class="step-label">Configure</span>
          </button>
        </li>
        <li class="step-item">
          <button id="step-launch" type="button" class="step" aria-selected="false" aria-controls="status-section" role="tab" disabled>
            <span class="step-index">2</span>
            <span class="step-label">Starting Services</span>
          </button>
        </li>
        <li class="step-item">
          <button id="step-complete" type="button" class="step" aria-selected="false" aria-controls="complete-section" role="tab" disabled>
            <span class="step-index">3</span>
            <span class="step-label">Complete</span>
          </button>
        </li>
        <li class="log-item">
          <button id="step-log" type="button" class="step utility-tab" aria-selected="false" aria-controls="log-section" role="tab">
            <span class="step-label">Log</span>
          </button>
        </li>
      </ol>
    </nav>

    <div id="setup-layout">
      <section id="config-section" class="panel" data-tab="configure" role="tabpanel" aria-labelledby="step-config">
        <h3>1. Configuration</h3>
        <p id="config-locked-note" hidden><strong>⚠️ Settings are now locked.</strong> Setup is in progress below.</p>
        <form id="config-form" data-disabled="<%= isConfigSaved %>">
          <label>
            MediaWiki Admin Email Address:
            <div class="field-help">Used for MediaWiki admin and alerts.</div>
            <input name="MW_ADMIN_EMAIL" type="email" required />
          </label>
          <label>
            Wikibase Host:
            <div class="field-help">
              Either a DNS A record resolving to <%= SERVER_IP %> or a localhost *.test domain
              <span class="help-actions">
                <a href="#" data-modal-open data-modal-target="dns-help-dialog" aria-label="DNS help">Help</a>
              </span>
            </div>
            <input name="WIKIBASE_PUBLIC_HOST" type="text" />
          </label>
          <label>
            Query Service Host:
            <div class="field-help">
              Either a DNS A record resolving to <%= SERVER_IP %> or a localhost *.test domain
              <br />
              <em>default: <pre style="display: inline;">query.&lt;Wikibase Host&gt;</pre></em>
              <span class="help-actions">
                <a href="#" data-modal-open data-modal-target="dns-help-dialog" aria-label="DNS help">Help</a>
              </span>
            </div>
            <input name="WDQS_PUBLIC_HOST" type="text" />
          </label>
          <details name="config">
            <summary role="secondary" style="font-weight: bold;">Advanced Options</summary>
            <label>
              MediaWiki Admin Name:
              <div class="field-help">Will be the login name for the MediaWiki admin</div>
              <input name="MW_ADMIN_NAME" />
            </label>
            <label>
              MediaWiki Admin Password:
              <div class="field-help">Minimum 10 characters. <em>default: randomly generated and revealed at end of install</em></div>
              <input name="MW_ADMIN_PASS" type="password" />
            </label>
            <label>
              Database Name:
              <div class="field-help"><em>default: my_wiki</em></div>
              <input name="DB_NAME" />
            </label>
            <label>
              Database User:
              <div class="field-help">Used by MediaWiki to connect to the database. <em>default: sqluser</em></div>
              <input name="DB_USER" />
            </label>
            <label>Database Password:
              <div class="field-help">Minimum 10 characters. <em>default: randomly generated and revealed at end of install</em></div>
              <input name="DB_PASS" type="password" />
            </label>
          </details>
          <label>
            <input
              type="checkbox"
              name="METADATA_CALLBACK"
              role="switch"
            />
            I want this Wikibase to be visible in the global Wikibase directory
          </label>
          <br />
          <button type="submit">Save</button>
        </form>
      </section>

      <section id="status-section" class="panel" data-tab="launch" role="tabpanel" aria-labelledby="step-launch" hidden>
        <h3>2. Setup Progress</h3>
        <p id="status-intro">Setup is running. Live progress is shown below.</p>
        <div id="waiting" hidden></div>
      </section>

      <section id="complete-section" class="panel" data-tab="complete" role="tabpanel" aria-labelledby="step-complete" hidden>
        <h3>3. Setup Complete</h3>
        <div id="complete" <%= isBooted ? '' : 'hidden' %>>
          <p>
            <strong>✅ Services started successfully!</strong>
            <br /><br />
            MediaWiki/Wikibase:
            <br />
            <a target="_blank" data-bind="WIKIBASE_PUBLIC_HOST" data-prefix="https://">https://</a>
            <br /><br />
            Query Service:
            <br />
            <a target="_blank" data-bind="WDQS_PUBLIC_HOST" data-prefix="https://">https://</a>
            <br /><br />
            QuickStatements:
            <br />
            <a target="_blank" data-bind="WIKIBASE_PUBLIC_HOST" data-prefix="https://" data-suffix="/tools/quickstatements">https:///tools/quickstatements</a>
          </p>

          <section id="saved-config">
            <p>
              <strong>⚠️ Please save this configuration somewhere secure. The passwords will be removed after this installation is complete.</strong>
            </p>
            <pre id="config-content"></pre>
            <button id="copy-config">Copy</button>
            <a id="download-config" href="#" download="wbs-deploy-setup.env">Download as a wbs-deploy-setup.env file</a>
          </section>
        </div>
      </section>

      <section id="log-section" class="panel" data-tab="log" role="tabpanel" aria-labelledby="step-log" hidden>
        <h3>Installer Log</h3>
        <pre id="log-content">Loading logs...</pre>
        <div id="log-actions">
          <p id="shutdown-help">
            Stop only after setup completes or if you intentionally want to cancel this installer session.
          </p>
          <button id="shutdown-btn">Shut Down Installer</button>
          <p id="shutdown-msg"></p>
        </div>
      </section>
    </div>
  </main>

  <dialog id="dns-help-dialog">
    <article>
      <h3>How to register a domain and point it here</h3>
      <p>This server's public IP address is: <code><%= SERVER_IP %></code></p>
      <ol>
        <li>Register a domain name with any common registrar (e.g., Cloudflare, Namecheap, etc).</li>
        <li>Open your domain’s DNS settings.</li>
        <li>Create an <strong>A record</strong>:
          <ul>
            <li><strong>Type</strong>: <code>A</code></li>
            <li><strong>Name/Host</strong>: <code>wikibase</code> (or blank/<code>@</code> for root)</li>
            <li><strong>Value</strong>: <code><%= SERVER_IP %></code></li>
          </ul>
        </li>
        <li>Create another A record for <code>query</code> pointing to the same IP.</li>
        <li>It may take a few minutes for new DNS entries to propagate.</li>
      </ol>
      <p class="help-small">
        <em>
          For testing and development <code>localhost</code> or <code>.test</code> domains (e.g. <code>wikibase.test</code>) are allowed.
          Another option is to use <code><%= SERVER_IP %>.nip.io</code> and <code>query.<%= SERVER_IP %>.nip.io</code> "magic" addresses
          which will automatically resolve to this server's IP address. In all cases use with caution as it is currently not easy
          to change these host names after initial WBS Deploy setup. 
        </em>
      </p>
      <footer>
        <button data-modal-close class="secondary">Close</button>
      </footer>
    </article>
  </dialog>

  <script>
    (function () {
      'use strict';

      const STATUS_LOG_ENTRY_REGEX = /\[status\]\s*(.*)$/i;
      const BOOT_COMPLETE_REGEX = /setup is complete!?/i;

      const el = (id) => document.getElementById(id);
      const on = (node, type, handler) => node && node.addEventListener(type, handler);

      function openSSE(url, { onOpen, onMessage, onError, events } = {}) {
        const es = new EventSource(url, { withCredentials: false });
        if (onOpen) es.onopen = onOpen;
        if (onMessage) es.onmessage = onMessage;
        if (onError) es.onerror = onError;
        if (events) Object.entries(events).forEach(([t, fn]) => es.addEventListener(t, fn));
        return es;
      }

      const form = el('config-form');
      const elStepConfig = el('step-config');
      const elStepLaunch = el('step-launch');
      const elStepComplete = el('step-complete');
      const elStepLog = el('step-log');
      const elConfigSection = el('config-section');
      const elStatusSection = el('status-section');
      const elCompleteSection = el('complete-section');
      const elLogSection = el('log-section');
      const elConfigLockedNote = el('config-locked-note');
      const elStatusIntro = el('status-intro');
      const elWaiting = el('waiting');
      const elComplete = el('complete');
      const elConfigContent = el('config-content');
      const elCopyBtn = el('copy-config');
      const elDownloadLink = el('download-config');
      const elLogContent = el('log-content');
      const elShutdownBtn = el('shutdown-btn');
      const elShutdownMsg = el('shutdown-msg');

      let logStream = null;
      let alreadyHandledBootedState = false;

      // --- New: shared page state & hydrators ---

      const pageState = { config: null, configText: '' };
      const orderedSteps = [ 'configure', 'launch', 'complete' ];
      const stepNodes = {
        configure: elStepConfig,
        launch: elStepLaunch,
        complete: elStepComplete
      };
      const panelNodes = {
        configure: elConfigSection,
        launch: elStatusSection,
        complete: elCompleteSection,
        log: elLogSection
      };

      let currentSetupStage = 'configure';
      let maxReachedStepIndex = 0;
      let activeTab = 'configure';

      function updateStepTabs() {
        const currentIndex = orderedSteps.indexOf(currentSetupStage);
        const activeIndex = orderedSteps.indexOf(activeTab);

        orderedSteps.forEach((name, index) => {
          const node = stepNodes[name];
          if (!node) return;

          node.classList.remove('is-active', 'is-done', 'is-current');
          node.removeAttribute('aria-current');
          node.setAttribute('aria-selected', 'false');
          node.disabled = index > maxReachedStepIndex;

          if (index < currentIndex) {
            node.classList.add('is-done');
          }
          if (index === currentIndex) {
            node.classList.add('is-current');
          }
          if (index === activeIndex) {
            node.classList.add('is-active');
            node.setAttribute('aria-selected', 'true');
          }
          if (index === currentIndex) {
            node.setAttribute('aria-current', 'step');
          }

          const indexNode = node.querySelector('.step-index');
          if (indexNode) {
            indexNode.textContent = index < currentIndex ? '✓' : String(index + 1);
          }
        });

        if (elStepLog) {
          const isLogTabActive = activeTab === 'log';
          elStepLog.classList.toggle('is-active', isLogTabActive);
          elStepLog.setAttribute('aria-selected', isLogTabActive ? 'true' : 'false');
          if (isLogTabActive) {
            elStepLog.setAttribute('aria-current', 'step');
          } else {
            elStepLog.removeAttribute('aria-current');
          }
        }
      }

      function setActiveTab(tab) {
        const isLogTab = tab === 'log';
        const tabIndex = orderedSteps.indexOf(tab);
        if (!isLogTab && (tabIndex === -1 || tabIndex > maxReachedStepIndex)) return;

        activeTab = tab;
        Object.entries(panelNodes).forEach(([name, panel]) => {
          if (!panel) return;
          panel.hidden = name !== activeTab;
        });

        const activePanel = panelNodes[activeTab];
        if (activePanel) {
          const activeBg = window.getComputedStyle(activePanel).backgroundColor || '#ffffff';
          document.documentElement.style.setProperty('--tab-active-bg', activeBg);
        } else {
          document.documentElement.style.setProperty('--tab-active-bg', '#ffffff');
        }

        updateStepTabs();
      }

      function setSetupStep(step) {
        const stepIndex = orderedSteps.indexOf(step);
        if (stepIndex === -1) return;
        currentSetupStage = step;
        maxReachedStepIndex = Math.max(maxReachedStepIndex, stepIndex);
        setActiveTab(step);
      }

      on(elStepConfig, 'click', (e) => {
        e.preventDefault();
        setActiveTab('configure');
      });
      on(elStepLaunch, 'click', (e) => {
        e.preventDefault();
        setActiveTab('launch');
      });
      on(elStepComplete, 'click', (e) => {
        e.preventDefault();
        setActiveTab('complete');
      });
      on(elStepLog, 'click', (e) => {
        e.preventDefault();
        setActiveTab('log');
      });

      function setConfigLockedState(locked) {
        if (elConfigSection) {
          elConfigSection.classList.toggle('is-locked', locked);
        }
        if (elConfigLockedNote) {
          elConfigLockedNote.hidden = !locked;
        }
        if (form) {
          form.setAttribute('aria-disabled', locked ? 'true' : 'false');
        }
      }

      function showWaitingStartMessage() {
        if (!elWaiting) return;
        if (elWaiting.children.length > 0) return;
        const msg = document.createElement('div');
        msg.className = 'status-line';
        msg.textContent = 'Configuration saved. Waiting for startup updates...';
        elWaiting.appendChild(msg);
      }

      async function fetchConfig() {
        try {
          const res = await fetch('/config');
          if (!res.ok) return;
          const { config, configText } = await res.json();
          pageState.config = config || {};
          pageState.configText = configText || '';
        } catch {}
      }

      function hydrateFormFromConfig(form, cfg) {
        if (!form || !cfg) return;
        form.querySelectorAll('input, select, textarea').forEach(el => {
          const name = el.getAttribute('name');
          if (!name || !(name in cfg)) return;
          const val = cfg[name];

          // switches/checkboxes
          if (el.type === 'checkbox' || el.getAttribute('role') === 'switch') {
            const on = (typeof val === 'boolean') ? val : String(val).toLowerCase() === 'true' || String(val) === '1';
            el.checked = on;
            return;
          }

          // don't overwrite password with empty
          if (el.type === 'password' && (val == null || String(val) === '')) return;

          el.value = (val ?? '');
        });
      }

      function hydrateBindingsFromConfig(cfg) {
        document.querySelectorAll('[data-bind]').forEach(node => {
          const key = node.dataset.bind;
          const prefix = node.dataset.prefix || '';
          const suffix = node.dataset.suffix || '';
          const v = cfg && cfg[key];

          if (!v) {
            // keep formatting placeholder text present but inert
            if (node.tagName === 'A') node.removeAttribute('href');
            // leave existing text (like "https://" scaffolding) as-is
            return;
          }

          const rendered = `${prefix}${v}${suffix}`;

          // text preserves the "final URL" formatting exactly
          node.textContent = rendered;

          if (node.tagName === 'A') {
            node.setAttribute('href', rendered);
          }
        });
      }

      function renderConfigTextBlock(preEl) {
        if (!preEl) return;
        preEl.textContent = pageState.configText || '';
      }

      // --- existing helpers ---

      function appendToLog(text) {
        const t = text.endsWith('\n') ? text : text + '\n';
        elLogContent.insertAdjacentText('beforeend', t);
      }

      function appendStatusLine(text) {
        if (!text) return;
        const div = document.createElement('div');
        div.className = 'status-line';
        div.textContent = text;
        elWaiting.appendChild(div);
      }

      function extractStatusLines(text) {
        if (!text) return [];
        return text
          .split('\n')
          .map((line) => {
            const m = line.match(STATUS_LOG_ENTRY_REGEX);
            return (m && m[1]) ? m[1].trim() : null;
          })
          .filter(Boolean);
      }

      async function handleBootComplete() {
        if (alreadyHandledBootedState) return;

        alreadyHandledBootedState = true;
        setConfigLockedState(true);
        setSetupStep('complete');
        if (elStatusIntro) {
          elStatusIntro.textContent = 'Setup complete. Your service links and saved configuration are below.';
        }

        // refresh config and hydrate UI
        await fetchConfig();
        hydrateFormFromConfig(form, pageState.config);
        hydrateBindingsFromConfig(pageState.config);
        renderConfigTextBlock(elConfigContent);

        elWaiting.hidden = true;
        elComplete.hidden = false;

        const configContent = pageState.configText || '';

        elCopyBtn.onclick = () => {
          navigator.clipboard.writeText(configContent).then(() => {
            elCopyBtn.textContent = 'Copied!';
            setTimeout(() => (elCopyBtn.textContent = 'Copy'), 2000);
          }).catch(() => {
            alert('⚠️ Failed to copy. Please do it manually.');
          });
        };

        if (elDownloadLink.href && elDownloadLink.href.startsWith('blob:')) {
          URL.revokeObjectURL(elDownloadLink.href);
        }
        const blob = new Blob([configContent], { type: 'text/plain' });
        elDownloadLink.href = URL.createObjectURL(blob);
      }

      function startLogStream() {
        if (logStream) return;

        logStream = openSSE('/log/stream', {
          onMessage: (e) => {
            if (!e.data) return;

            const lines = JSON.parse(e.data); // always unwraps the quotes

            extractStatusLines(lines).forEach(appendStatusLine);

            if (BOOT_COMPLETE_REGEX.test(lines)) {
              handleBootComplete();
            }

            appendToLog(lines);
          },
          onError: () => {
            console.log('SSE error (will auto-reconnect)');
          }
        });
      }

      function initValidation() {
        const hostNameRegex = /^(localhost|([a-zA-Z0-9-]+\.)+[a-zA-Z]{2,})$/;
        const passwordValidator = (value) => value.length === 0 || value.length >= 10;

        const hostResolvesToServerIPRule = {
          validator: value => async () => {
            const hostname = (value || '').trim();
            if (!hostname) return true;
            if (hostname === 'localhost' || /\.test$/i.test(hostname)) return true;
            try {
              const res = await fetch(`https://dns.google/resolve?name=${encodeURIComponent(hostname)}&type=A`);
              if (!res.ok) return false;
              const json = await res.json();
              const answers = Array.isArray(json?.Answer) ? json.Answer : [];
              return answers.some(a => a.type === 1 && a.data === '<%= SERVER_IP %>');
            } catch {
              return false;
            }
          },
          errorMessage: `Doesn't resolve to <%= SERVER_IP %>`
        };
        
        startLogStream();

        const validate = new JustValidate('#config-form');

        validate
          .addField('[name=MW_ADMIN_EMAIL]', [
            { rule:'required' },
            { rule:'email' }
          ])
          .addField('[name=WIKIBASE_PUBLIC_HOST]', [
            { rule:'required' },
            { rule:'customRegexp', value: hostNameRegex, errorMessage: 'Must be a valid hostname (e.g. example.com)' },
            hostResolvesToServerIPRule
          ])
          .addField('[name=WDQS_PUBLIC_HOST]', [
            { rule:'customRegexp', value: hostNameRegex, errorMessage: 'Must be a valid hostname (e.g. query.example.com)' },
            hostResolvesToServerIPRule
          ])
          .addField('[name=MW_ADMIN_PASS]', [
            { validator: passwordValidator, errorMessage: 'Password must be at least 10 characters or left blank' }
          ])
          .addField('[name=DB_PASS]', [
            { validator: passwordValidator, errorMessage: 'Password must be at least 10 characters or left blank' }
          ])
          .onSuccess(async (event) => {
            const f = event.target;
            const data = Object.fromEntries(new FormData(f).entries());
            data.METADATA_CALLBACK = f.METADATA_CALLBACK?.checked ? 'true' : 'false';

            const res = await fetch('/config', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });

            if (res.ok) {
              // lock form
              f.querySelectorAll('input, button').forEach((i) => (i.disabled = true));
              setConfigLockedState(true);
              setSetupStep('launch');
              if (elStatusIntro) {
                elStatusIntro.textContent = 'Setup is running. Live progress is shown below.';
              }

              // echo back saved config for coherence
              const { config, configText } = await res.json();
              pageState.config = config || {};
              pageState.configText = configText || '';

              hydrateFormFromConfig(f, pageState.config);
              hydrateBindingsFromConfig(pageState.config);
              renderConfigTextBlock(elConfigContent);

              elWaiting.hidden = false;
              elWaiting.innerHTML = '';
              showWaitingStartMessage();
              elComplete.hidden = true;
            } else {
              alert('Failed to save environment. See console for details.');
            }
          });
      }

      (function wdqsHostDefault() {
        const wbHostInput = form.querySelector('[name=WIKIBASE_PUBLIC_HOST]');
        const wdqsHostInput = form.querySelector('[name=WDQS_PUBLIC_HOST]');
        if (!wbHostInput || !wdqsHostInput) return;

        const derive = v => v ? `query.${v}` : '';

        wbHostInput.addEventListener('input', () => {
          if (wdqsHostInput.dataset.defaulted === 'true') {
            wdqsHostInput.value = derive(wbHostInput.value.trim());
          }
        });

        wdqsHostInput.addEventListener('input', () => {
          wdqsHostInput.dataset.defaulted = wdqsHostInput.value.trim() ? 'false' : 'true';
          if (wdqsHostInput.dataset.defaulted === 'true') {
            wdqsHostInput.value = derive(wbHostInput.value.trim());
          }
        });

        if (!wdqsHostInput.value.trim()) wdqsHostInput.dataset.defaulted = 'true';
      })();

      // Bindings
      // Minimal wiring for Pico-styled dialogs using data attributes
      document.addEventListener('click', (e) => {
        const opener = e.target.closest('[data-modal-open]');
        if (opener) {
          e.preventDefault();
          const id = opener.getAttribute('data-modal-target');
          const dlg = id && document.getElementById(id);
          if (dlg) dlg.showModal();
          return;
        }
        const closer = e.target.closest('[data-modal-close]');
        if (closer) {
          e.preventDefault();
          const dlg = closer.closest('dialog');
          if (dlg) dlg.close();
        }
      });

      on(elShutdownBtn, 'click', async (e) => {
        e.preventDefault();
        if (!elShutdownBtn) return;

        elShutdownBtn.disabled = true;
        elShutdownMsg.textContent = 'Shutting down installer...';

        try {
          const res = await fetch('/finalize-setup', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
          if (res.ok) elShutdownMsg.textContent = '✅ Finalized. The installer will stop shortly.';
          else {
            elShutdownMsg.textContent = `❌ Finalize failed (HTTP ${res.status}). Check logs.`;
            elShutdownBtn.disabled = false;
          }
        } catch (err) {
          console.error(err);
          elShutdownMsg.textContent = '❌ Network error while finalizing. See console/logs.';
          elShutdownBtn.disabled = false;
        }
      });

      const initializePage = async () => {
        initValidation();

        // get config once and hydrate everything
        await fetchConfig();

        hydrateFormFromConfig(form, pageState.config);
        hydrateBindingsFromConfig(pageState.config);
        renderConfigTextBlock(elConfigContent);

        if (form.dataset.disabled === 'true') {
          setConfigLockedState(true);
          // .env config file already saved, disable inputs
          form.querySelectorAll('input, button').forEach((el) => (el.disabled = true));

          // If server didn't render #complete (not booted), start in waiting mode
          if (elComplete.hasAttribute('hidden')) {
            if (elWaiting) elWaiting.hidden = false;
            showWaitingStartMessage();
            setSetupStep('launch');
            if (elStatusIntro) {
              elStatusIntro.textContent = 'Setup is running. Live progress is shown below.';
            }
          } else {
            setSetupStep('complete');
            if (elStatusIntro) {
              elStatusIntro.textContent = 'Setup complete. Your service links and saved configuration are below.';
            }
          }
        } else {
          setConfigLockedState(false);
          setSetupStep('configure');
          // Fresh start: nothing in status yet
          elWaiting.hidden = true;
          elComplete.hidden = true;
          if (elStatusIntro) {
            elStatusIntro.textContent = 'Save your configuration to begin setup.';
          }
        }
      }

      window.addEventListener('DOMContentLoaded', initializePage);
    })();
  </script>
</body>
</html>
