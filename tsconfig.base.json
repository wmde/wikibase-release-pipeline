{
  "compileOnSave": false,
	"compilerOptions": {
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "rootDir": ".",
		"esModuleInterop": true,
		"module": "Node16",
		"sourceMap": true,
		"target": "es2019",
    "baseUrl": ".",
		"types": [ "node", "@wdio/globals/types", "@wdio/mocha-framework" ],
    "lib": ["es2020"],
    "paths": {
      "@wbs": ["."]
    }
	},
	"ts-node": {
		"files": true,
		"esm": true
	},
	"include": [ "./**/*.ts", "./**/*.mjs" ]
}
